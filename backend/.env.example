# ── Backend EPiC Playground ──────────────────────────────────────────────────
# Copia este archivo como .env y ajusta los valores.
# En Railway estas variables se configuran en el panel de la plataforma.

# Puerto en el que corre uvicorn (Railway lo asigna automáticamente)
PORT=8000

# URL del frontend (separada por comas si hay varios orígenes)
# Ejemplo producción: https://epic-frontend.up.railway.app
# En desarrollo: dejar en * para aceptar cualquier origen
CORS_ORIGIN=*
